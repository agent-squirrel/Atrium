# Use Docker's embedded DNS so upstreams are resolved at request time,
# not at startup - prevents "host not found" when containers start in any order.
resolver 127.0.0.11 valid=10s ipv6=off;

server {
    listen 80;
    root /usr/share/nginx/html;
    absolute_redirect off;

    # If this deployment sits behind another reverse proxy (Caddy, Traefik,
    # a cloud load balancer), set TRUSTED_PROXY_CIDR to its address.
    set_real_ip_from ${TRUSTED_PROXY_CIDR};
    real_ip_header X-Forwarded-For;
    real_ip_recursive on;

    # Pass the real client IP through to Flask
    proxy_set_header Host              $http_host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Flask backend routes
    location /api/ {
        set $backend http://backend:5000;
        proxy_pass $backend;
    }

    location /p/ {
        set $backend http://backend:5000;
        proxy_pass $backend;
    }

    location /static/ {
        set $backend http://backend:5000;
        proxy_pass $backend;
    }

    location /guest/ {
        set $backend http://backend:5000;
        proxy_pass $backend;
    }

    # Admin SPA - served directly as static files, built in the image's node stage
    location /admin {
        try_files $uri $uri/ /admin/index.html;
    }

    # Backend startup-stage marker (see backend/entrypoint.sh) - plain static
    # file served straight off disk, so it's reachable even before gunicorn
    # is listening. Never cache it, the whole point is that it changes.
    location /status/ {
        add_header Cache-Control "no-store";
    }

    # Root - handled by Flask (configurable redirect). While the backend is
    # still starting up, fall back to the admin SPA instead of a raw 502
    location / {
        set $backend http://backend:5000;
        proxy_pass $backend;
        error_page 502 503 504 = @backend_starting;
    }

    location @backend_starting {
        return 302 /admin/;
    }
}
