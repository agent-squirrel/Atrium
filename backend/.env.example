# cp .env.example .env, then replace every REQUIRED value below.

FLASK_ENV=production

# REQUIRED - generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# REQUIRED - generate a different value with the same command as above
JWT_SECRET_KEY=change-me-to-another-long-random-string

POSTGRES_DB=atrium_db
POSTGRES_USER=atrium_user
# REQUIRED - generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=change-me-to-a-strong-password

# REQUIRED - generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# OPTIONAL - only needed if nginx sits behind another reverse proxy
# TRUSTED_PROXY_CIDR=10.0.1.20
